ABOUTUS_MONITOR_CONFIG=/home/aboutus/aboutus-network-monitor/config/network.yaml
ABOUTUS_MONITOR_HOST=0.0.0.0
ABOUTUS_MONITOR_PORT=8080
ABOUTUS_MONITOR_DB=/home/aboutus/aboutus-network-monitor/data/monitor.sqlite3

# Optional read-only SNMP. Do not commit real SNMP credentials.
ABOUTUS_SNMP_COMMUNITY=
ABOUTUS_SNMP_VERSION=2c
ABOUTUS_SNMP_TIMEOUT_SECONDS=2
ABOUTUS_SNMP_RETRIES=0
